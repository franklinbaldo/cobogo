---
interface Props {
  type?: 'info' | 'tip' | 'warning' | 'danger' | 'note';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const config = {
  info: { color: 'var(--azul, #0056b3)', bg: 'var(--azul-soft, #e6f0fa)', icon: '<circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="8"/><path d="M50 30v10M50 50v20" stroke="currentColor" stroke-width="8" stroke-linecap="round"/>' },
  tip: { color: 'var(--verde, #28a745)', bg: 'var(--verde-soft, #eaf6ec)', icon: '<path d="M50 20 L80 80 L20 80 Z" fill="none" stroke="currentColor" stroke-width="8" stroke-linejoin="round"/>' },
  warning: { color: 'var(--ocre, #d39e00)', bg: 'var(--ocre-soft, #fdf6e3)', icon: '<polygon points="50,20 90,80 10,80" fill="none" stroke="currentColor" stroke-width="8" stroke-linejoin="round"/><line x1="50" y1="45" x2="50" y2="60" stroke="currentColor" stroke-width="8" stroke-linecap="round"/><circle cx="50" cy="70" r="4" fill="currentColor"/>' },
  danger: { color: 'var(--vermelho, #dc3545)', bg: 'var(--vermelho-soft, #fcebec)', icon: '<rect x="20" y="20" width="60" height="60" fill="none" stroke="currentColor" stroke-width="8"/><line x1="30" y1="30" x2="70" y2="70" stroke="currentColor" stroke-width="8"/><line x1="70" y1="30" x2="30" y2="70" stroke="currentColor" stroke-width="8"/>' },
  note: { color: 'var(--concreto-60, #6c757d)', bg: 'var(--bg-soft, #f8f9fa)', icon: '<rect x="30" y="20" width="40" height="60" fill="none" stroke="currentColor" stroke-width="8" stroke-linejoin="round"/><line x1="40" y1="40" x2="60" y2="40" stroke="currentColor" stroke-width="8" stroke-linecap="round"/><line x1="40" y1="60" x2="60" y2="60" stroke="currentColor" stroke-width="8" stroke-linecap="round"/>' },
};

const currentConfig = config[type];
const defaultTitle = title || type.charAt(0).toUpperCase() + type.slice(1);
---

<div class="callout" style={`--callout-color: ${currentConfig.color}; --callout-bg: ${currentConfig.bg};`}>
  <div class="callout-header">
    <svg viewBox="0 0 100 100" class="callout-icon" set:html={currentConfig.icon} />
    <span class="callout-title">{defaultTitle}</span>
  </div>
  <div class="callout-body">
    <slot />
  </div>
</div>
