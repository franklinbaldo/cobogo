---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchBar from '../SearchBar.svelte';
import PostCard from './PostCard.svelte';
import TagChip from './TagChip.svelte';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Acervo',
  description = 'Ensaios, notas e reflexões sobre design de serviço público.',
} = Astro.props;

const posts = [
  {
    title: 'O Modernismo como Serviço Público',
    description: 'Como as lições de Lina Bo Bardi e Athos Bulcão podem informar o design de interfaces cívicas hoje.',
    pubDate: '12 Mar 2026',
    slug: 'modernismo-servico-publico',
    tags: ['Design System', 'História'],
    heroImage: 'https://images.unsplash.com/photo-1541893309623-64e320f26210?q=80&w=1200&auto=format&fit=crop',
  },
  {
    title: 'Densidade de Informação em Telas de Triagem',
    description: 'Estudo de caso no projeto CausaGanha: porque espaços em branco em excesso atrapalham a leitura técnica.',
    pubDate: '05 Fev 2026',
    slug: 'densidade-informacao-triagem',
    tags: ['UX', 'Estudo de Caso'],
  },
  {
    title: 'Construindo o componente Cobogó',
    description: 'Os desafios técnicos de criar padrões SVG modulares e acessíveis.',
    pubDate: '20 Jan 2026',
    slug: 'construindo-componente-cobogo',
    tags: ['Desenvolvimento', 'Acessibilidade'],
  },
];

const allTags = ['Design System', 'História', 'UX', 'Estudo de Caso', 'Desenvolvimento', 'Acessibilidade', 'Brasília', 'Tipografia'];
---

<BaseLayout title={`${title} | COBOGÓ Blog`}>
  <header data-region="site-header" data-archive-header>
    <a href="/cobogo/blog-application">
      <strong>COBOGÓ</strong>
      <small>Blog</small>
    </a>
  </header>

  <main data-archive>
    <header data-page-header>
      <hgroup>
        <h1>{title}</h1>
        <p>{description}</p>
      </hgroup>
      <div data-archive-search>
        <SearchBar client:load placeholder="Buscar no acervo..." />
      </div>
    </header>

    <div data-archive-layout>
      <aside data-archive-side>
        <h3>Tópicos</h3>
        <ul>
          {allTags.map((tag) => (
            <li><TagChip tag={tag} /></li>
          ))}
        </ul>
      </aside>

      <section data-archive-feed>
        {posts.map((post) => (
          <PostCard
            title={post.title}
            description={post.description}
            pubDate={post.pubDate}
            slug={post.slug}
            tags={post.tags}
            heroImage={post.heroImage}
            variant="compact"
          />
        ))}

        <div data-archive-pagination>
          <button type="button" data-intent="secondary">Carregar mais antigos</button>
        </div>
      </section>
    </div>
  </main>

  <footer data-region="site-footer" data-archive-footer>
    <p>© 2026 COBOGÓ. Um sistema visual brasileiro.</p>
  </footer>
</BaseLayout>

<style>
  [data-archive-header] {
    padding: 2rem;
    border-bottom: 1px solid var(--border);
  }
  [data-archive-header] a {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--fg-heading);
    text-decoration: none;
    display: inline-flex;
    gap: 0.5rem;
    align-items: baseline;
    max-width: 1240px;
    margin: 0 auto;
  }
  [data-archive-header] a strong {
    font-weight: 900;
    letter-spacing: -0.05em;
  }
  [data-archive-header] a small { font-weight: 400; color: var(--fg-muted); }

  [data-archive] {
    flex: 1;
    padding: 4rem 2rem 8rem;
    max-width: 1240px;
    margin: 0 auto;
  }
  [data-archive] > [data-page-header] { max-width: 800px; margin-bottom: 4rem; }
  [data-archive] > [data-page-header] hgroup h1 {
    font-size: var(--t-h1);
    margin: 0 0 1rem;
  }
  [data-archive] > [data-page-header] hgroup p {
    font-size: var(--t-lede);
    color: var(--fg-muted);
    margin: 0 0 2.5rem;
  }
  [data-archive-search] { max-width: 480px; margin: 0; }

  [data-archive-layout] {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 4rem;
    align-items: start;
  }
  [data-archive-side] h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    margin: 0 0 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  [data-archive-side] ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  [data-archive-feed] {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  [data-archive-pagination] { margin: 3rem 0 0; text-align: center; }

  [data-archive-footer] {
    padding: 4rem 2rem;
    background: var(--bg-raised);
    border-top: 1px solid var(--border);
    text-align: center;
    color: var(--fg-muted);
    font-size: 0.875rem;
  }

  @media (max-width: 900px) {
    [data-archive-layout] { grid-template-columns: 1fr; }
  }
</style>
