---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import Grid from '../components/Grid.svelte';
import Column from '../components/Column.svelte';
import DataTable from '../components/DataTable.svelte';
import FilterBar from '../components/FilterBar.svelte';
import DatePicker from '../components/DatePicker.svelte';
import TimePicker from '../components/TimePicker.svelte';
import TextInput from '../components/TextInput.svelte';
import FormField from '../components/FormField.svelte';
import Button from '../components/Button.svelte';
import Card from '../components/Card.svelte';
import Combobox from '../components/Combobox.svelte';
import MultiSelect from '../components/MultiSelect.svelte';
---

<BaseLayout title="Composition | COBOGÓ">
  <SiteNav currentPath={Astro.url.pathname} />

  <main>
    <header data-page-header>
      <hgroup>
        <h1>Painel Cívico</h1>
        <p>Demonstração da doutrina <em>"never the same wall twice"</em>. Uma composição complexa de organismos interativos: Filtros, Tabelas, Data e Hora.</p>
      </hgroup>
    </header>

    <section data-composition>
      <Grid gap="2rem">
        <Column span={12} lg={4}>
          <Card>
            <h2>Filtros Avançados</h2>

            <FormField client:load label="Termo de Busca" htmlFor="search-input">
              <TextInput id="search-input" placeholder="Ex: Contratos, Editais..." />
            </FormField>

            <FormField client:load label="Departamento" htmlFor="dept-combobox">
              <Combobox
                client:load
                id="dept-combobox"
                placeholder="Selecione o órgão..."
                options={[
                  { value: 'saude', label: 'Secretaria de Saúde' },
                  { value: 'educacao', label: 'Secretaria de Educação' },
                  { value: 'infra', label: 'Infraestrutura e Obras' },
                  { value: 'fazenda', label: 'Fazenda Pública' },
                  { value: 'meio-ambiente', label: 'Meio Ambiente' }
                ]}
              />
            </FormField>

            <FormField client:load label="Etiquetas (Tags)" htmlFor="tags-multiselect">
              <MultiSelect
                client:load
                id="tags-multiselect"
                placeholder="Filtrar por tags..."
                options={[
                  { value: 'ativo', label: 'Ativo' },
                  { value: 'encerrado', label: 'Encerrado' },
                  { value: 'urgente', label: 'Urgente' },
                  { value: 'em-revisao', label: 'Em Revisão' },
                  { value: 'auditoria', label: 'Auditoria' }
                ]}
              />
            </FormField>

            <FormField client:load label="Data Inicial" htmlFor="date-start"><DatePicker id="date-start" /></FormField>
            <FormField client:load label="Hora Inicial" htmlFor="time-start"><TimePicker id="time-start" /></FormField>
            <FormField client:load label="Data Final" htmlFor="date-end"><DatePicker id="date-end" /></FormField>
            <FormField client:load label="Hora Final" htmlFor="time-end"><TimePicker id="time-end" /></FormField>

            <footer data-actions>
              <Button client:load intent="primary">Aplicar Filtros</Button>
              <Button client:load intent="outline">Limpar</Button>
            </footer>
          </Card>
        </Column>

        <Column span={12} lg={8}>
          <header data-results-header>
            <h2>Resultados da Consulta</h2>
            <FilterBar client:load filters={[
              { key: 'estado', label: 'Estado', value: 'Ativo' },
              { key: 'ano', label: 'Ano', value: '2026' },
              { key: 'tipo', label: 'Tipo', value: 'Contratos' }
            ]} />
          </header>

          <DataTable
            client:load
            caption="Tabela de resultados cívicos"
            headers={[
              { key: 'id', label: 'ID' },
              { key: 'objeto', label: 'Objeto' },
              { key: 'data', label: 'Data', align: 'center' },
              { key: 'hora', label: 'Hora', align: 'center' },
              { key: 'valor', label: 'Valor', align: 'right' }
            ]}
            data={[
              { id: '1001', objeto: 'Reforma Estrutural', data: '2026-05-10', hora: '14:30', valor: 'R$ 1.250.000,00' },
              { id: '1002', objeto: 'Aquisição de TI', data: '2026-05-12', hora: '09:00', valor: 'R$ 450.000,00' },
              { id: '1003', objeto: 'Manutenção de Frota', data: '2026-05-15', hora: '16:45', valor: 'R$ 89.000,00' },
              { id: '1004', objeto: 'Consultoria Jurídica', data: '2026-05-18', hora: '10:15', valor: 'R$ 210.000,00' },
              { id: '1005', objeto: 'Licenciamento de Software', data: '2026-05-20', hora: '11:00', valor: 'R$ 150.000,00' }
            ]}
          />
        </Column>
      </Grid>
    </section>
  </main>

  <footer data-region="site-footer">
    <p><small data-kicker>DS v0.1.0 — Distribuível via NPM / TypeScript Node</small></p>
  </footer>
</BaseLayout>

<style>
  main { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  main > [data-page-header] { padding: 4rem 0 2rem; margin-bottom: 0; }
  main > [data-page-header] hgroup h1 {
    font-family: var(--font-display-alt);
    font-size: clamp(3rem, 6vw, 4rem);
    line-height: 0.9;
    margin: 0 0 1.5rem;
  }
  main > [data-page-header] hgroup p {
    font-size: 1.25rem;
    color: var(--fg-muted);
    max-width: 800px;
  }
  [data-composition] { padding: 2rem 0 4rem; }
  [data-composition] article h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin: 0 0 1.5rem;
  }
  [data-composition] article > footer[data-actions] {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    background: transparent;
    padding: 0;
    border: 0;
  }
  [data-results-header] {
    margin-bottom: 2rem;
    background: transparent;
    padding: 0;
    border: 0;
  }
  [data-results-header] h2 {
    font-family: var(--font-display);
    font-size: 2rem;
    margin: 0 0 1rem;
  }
  [data-region="site-footer"] {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    color: var(--fg-muted);
  }
</style>
