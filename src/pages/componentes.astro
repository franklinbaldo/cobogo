---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import Ornaments from '../components/Ornaments.astro';
import ProfileCard from '../components/ProfileCard.svelte';
import DataTable from '../components/DataTable.svelte';
import SearchBar from '../components/SearchBar.svelte';
import Button from '../components/Button.svelte';
import Badge from '../components/Badge.svelte';
import TextInput from '../components/TextInput.svelte';
import MultiSelect from '../components/MultiSelect.svelte';
import DatePicker from '../components/DatePicker.svelte';
import TimePicker from '../components/TimePicker.svelte';
import Switch from '../components/Switch.svelte';
import Checkbox from '../components/Checkbox.svelte';
import Radio from '../components/Radio.svelte';
import Alert from '../components/Alert.svelte';
import Notification from '../components/Notification.svelte';

const tableHeaders = [
  { key: 'id', label: 'ID' },
  { key: 'item', label: 'Item' },
  { key: 'valor', label: 'Status' },
];

const tableData = [
  { id: '01', item: 'Brasília', valor: 'Ativo' },
  { id: '02', item: 'Pampulha', valor: 'Pendente' },
];

const mockOptions = [
  { value: 'br', label: 'Brasil' },
  { value: 'ar', label: 'Argentina' },
  { value: 'uy', label: 'Uruguai' },
];
---

<BaseLayout title="Vitrine de Componentes | COBOGÓ">
  <aside aria-hidden="true" data-pattern="cobogo-circular" data-region="tile-sidebar"></aside>

  <SiteNav currentPath={Astro.url.pathname} />

  <main>
    <header data-page-header>
      <hgroup>
        <p><small data-kicker="vermelho">Biblioteca Atômica</small></p>
        <h1>Vitrine Curva<br />& Concreto</h1>
        <p>Uma visualização rápida de todos os componentes criados pelo agente <strong>Brad Frost</strong>, seguindo a arquitetura de átomos, moléculas e organismos.</p>
      </hgroup>
    </header>

    <Ornaments type="waveline" height={24} color="var(--concreto-30)" />

    <section data-showcase="atoms">
      <hgroup>
        <h2>01. Átomos</h2>
        <p>As menores unidades funcionais. Baseadas em geometria pura.</p>
      </hgroup>

      <div data-showcase-grid>
        <article>
          <h3>Botões</h3>
          <div data-stack>
            <Button client:load intent="primary">Primário</Button>
            <Button client:load intent="secondary">Secundário</Button>
          </div>
        </article>

        <article>
          <h3>Badges</h3>
          <div data-row>
            <Badge client:load intent="verde">Sucesso</Badge>
            <Badge client:load intent="azul">Info</Badge>
            <Badge client:load intent="vermelho">Erro</Badge>
          </div>
        </article>

        <article>
          <h3>Toggles</h3>
          <div data-row data-align="center">
            <label><Switch client:load /> Switch</label>
            <label><Checkbox client:load checked /> Checkbox</label>
            <label><Radio client:load value="r" group={'r'} /> Radio</label>
          </div>
        </article>

        <article>
          <h3>Inputs de Texto</h3>
          <label>
            Nome Completo
            <TextInput client:load placeholder="Ex: Oscar Niemeyer" />
          </label>
        </article>
      </div>
    </section>

    <section data-showcase="molecules">
      <hgroup>
        <h2>02. Moléculas</h2>
        <p>União de átomos para formar componentes mais complexos.</p>
      </hgroup>

      <div data-showcase-grid>
        <article>
          <h3>Seleção Múltipla</h3>
          <MultiSelect
            client:load
            options={mockOptions}
            placeholder="Escolha os países..."
            value={['br']}
          />
        </article>

        <article>
          <h3>Seleção de Data</h3>
          <label>Data de Fundação<DatePicker client:load /></label>
        </article>

        <article>
          <h3>Seleção de Horário</h3>
          <label>Horário de Início<TimePicker client:load /></label>
        </article>

        <article>
          <h3>Alertas</h3>
          <Alert client:load title="Atenção" intent="warning">
            Esta ação não pode ser desfeita após o salvamento.
          </Alert>
        </article>
      </div>
    </section>

    <section data-showcase="organisms">
      <hgroup>
        <h2>03. Organismos</h2>
        <p>Componentes robustos e prontos para aplicação em produtos reais.</p>
      </hgroup>

      <div data-showcase-grid data-variant="wide">
        <article>
          <h3>Tabelas de Dados</h3>
          <DataTable client:load headers={tableHeaders} data={tableData} variant="striped" />
        </article>

        <article>
          <h3>Barra de Busca Inteligente</h3>
          <SearchBar client:load placeholder="Pesquisar no sistema..." />
        </article>
      </div>

      <div data-showcase-grid>
        <article>
          <h3>Cartão de Perfil</h3>
          <ProfileCard
            client:load
            name="Lina Bo Bardi"
            role="Arquiteta e Designer"
            tags={['Vidro', 'Social']}
          />
        </article>

        <article>
          <h3>Notificações</h3>
          <div data-notification-stage>
            <Notification client:load intent="tip" title="Salvo">
              Seu projeto foi salvo com sucesso no servidor.
            </Notification>
          </div>
        </article>
      </div>
    </section>
  </main>

  <footer data-region="site-footer">
    <p><small data-kicker>COBOGÓ Design System — v0.1.0</small></p>
    <a href="/cobogo/docs/getting-started/">Ver documentação técnica completa →</a>
  </footer>
</BaseLayout>

<style is:global>
  body:has([data-region="tile-sidebar"]) { padding-left: 80px; }
  @media (max-width: 600px) { body:has([data-region="tile-sidebar"]) { padding-left: 0; } }
</style>

<style>
  main { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  main > [data-page-header] { padding: 8rem 0 4rem; }
  main > [data-page-header] hgroup h1 {
    font-family: var(--font-display-alt);
    font-size: 5rem;
    line-height: 0.9;
    margin: 0 0 2rem;
  }
  main > [data-page-header] hgroup p:last-child {
    font-size: 1.5rem;
    color: var(--fg-muted);
    max-width: 650px;
    line-height: 1.4;
  }

  main > section { padding: 6rem 0; }
  main > section hgroup h2 {
    font-size: 2.5rem;
    color: var(--azul);
    margin: 0 0 0.5rem;
  }
  main > section hgroup p {
    color: var(--fg-muted);
    margin: 0 0 3rem;
    font-size: 1.125rem;
  }

  [data-showcase-grid] {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }
  [data-showcase-grid] + [data-showcase-grid] { margin-top: 2rem; }
  [data-showcase-grid][data-variant="wide"] { grid-template-columns: 1fr; }

  [data-showcase-grid] article {
    background: var(--papel-00);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  [data-showcase-grid] article h3 {
    font-size: var(--t-small);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--concreto-60);
    margin: 0;
  }

  [data-row] { display: flex; flex-wrap: wrap; gap: 1rem; }
  [data-row][data-align="center"] { align-items: center; gap: 2rem; }
  [data-stack] { display: flex; flex-direction: column; gap: 1rem; }
  [data-notification-stage] { background: var(--bg-sunken); padding: 1rem; border-radius: var(--r-soft); }

  [data-region="site-footer"] {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  @media (max-width: 768px) {
    main > [data-page-header] hgroup h1 { font-size: 3.5rem; }
    [data-showcase-grid] { grid-template-columns: 1fr; }
  }
</style>
