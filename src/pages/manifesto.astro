---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import Button from '../components/Button.svelte';
import Card from '../components/Card.svelte';
import Badge from '../components/Badge.svelte';
---

<BaseLayout title="Manifesto do Sistema | COBOGÓ">
  <aside aria-hidden="true" data-pattern="cobogo-hexagonal" data-region="tile-sidebar"></aside>

  <SiteNav currentPath={Astro.url.pathname} />

  <main>
    <section data-section="manifesto-intro">
      <hgroup>
        <h1>Manifesto<br />do sistema</h1>
        <p>Calçadas de Ipanema + tipografia editorial paulista + modernismo brasileiro como linguagem de interface cívica.</p>
      </hgroup>

      <blockquote>
        <p>"COBOGÓ não é nostalgia modernista. É uma gramática visual para software brasileiro contemporâneo. Usa cor sem carnavalizar, geometria sem endurecer, ornamento sem ruído, e serviço público sem cara de repartição."</p>
      </blockquote>

      <dl data-section="principles">
        <div><dt>C. Cívico</dt><dd>Design orientado ao interesse e serviço público.</dd></div>
        <div><dt>O. Organizado</dt><dd>Informação estruturada com hierarquia editorial forte.</dd></div>
        <div><dt>B. Brasileiro</dt><dd>Referências locais com sofisticação contemporânea, sem caricatura.</dd></div>
        <div><dt>O. Objetivo</dt><dd>Clareza em primeiro lugar; ornamento apenas com função.</dd></div>
        <div><dt>G. Geométrico</dt><dd>Grids, blocos e padrões que constroem interfaces sólidas.</dd></div>
        <div><dt>Ó. Ótimo</dt><dd>Performance, acessibilidade e modularidade para o software moderno.</dd></div>
      </dl>
    </section>

    <section data-section="palette">
      <h2>Paleta de Cores</h2>
      <ul data-palette>
        <li><span data-swatch style="background:#E7DFCF"></span><span>Areia #E7DFCF</span></li>
        <li><span data-swatch style="background:#111111"></span><span>Preto #111111</span></li>
        <li><span data-swatch style="background:#0D387A"></span><span>Azul #0D387A</span></li>
        <li><span data-swatch style="background:#1B6B4A"></span><span>Verde #1B6B4A</span></li>
        <li><span data-swatch style="background:#E15B2A"></span><span>Terracota #E15B2A</span></li>
        <li><span data-swatch style="background:#F7F6F2; border:1px solid #ddd"></span><span>Branco #F7F6F2</span></li>
      </ul>
    </section>

    <section data-section="lab">
      <h2>Componentes</h2>

      <div data-lab-grid>
        <figure>
          <figcaption><small data-kicker>Botão Primário</small></figcaption>
          <Button intent="primary">Explorar acervo →</Button>
        </figure>
        <figure>
          <figcaption><small data-kicker>Botão Secundário</small></figcaption>
          <Button intent="outline">Saiba mais →</Button>
        </figure>
        <figure>
          <figcaption><small data-kicker>Badge</small></figcaption>
          <Badge intent="verde">Ativo</Badge>
        </figure>
      </div>

      <div data-lab-grid>
        <figure>
          <figcaption><small data-kicker>Card de Notícia</small></figcaption>
          <Card pattern="meias-luas">
            <p data-thumb></p>
            <h4>Nova exposição revisita a arquitetura de Brasília</h4>
            <p><small>24 MAI 2024 • Cultura</small></p>
          </Card>
        </figure>
        <figure>
          <figcaption><small data-kicker>Bloco de Citação</small></figcaption>
          <blockquote>
            <p>"A cidade é feita de encontros, de caminhos e de memória. Design é serviço público."</p>
            <footer><cite>Lina Bo Bardi</cite></footer>
          </blockquote>
        </figure>
      </div>
    </section>
  </main>

  <footer data-region="site-footer">
    <p><small data-kicker>Clareza Editorial. Ritmo Brasileiro. Serviço Público.</small></p>
  </footer>
</BaseLayout>

<style is:global>
  body:has([data-region="tile-sidebar"]) { padding-left: 80px; }
  @media (max-width: 600px) { body:has([data-region="tile-sidebar"]) { padding-left: 0; } }
</style>

<style>
  main { max-width: 1240px; margin: 0 auto; padding: 0 2rem; }

  [data-section="manifesto-intro"] {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    padding: 6rem 0;
    align-items: start;
  }
  [data-section="manifesto-intro"] hgroup h1 {
    font-size: 6rem;
    font-family: var(--font-display);
    line-height: 0.9;
    letter-spacing: -0.04em;
    margin: 0 0 2rem;
  }
  [data-section="manifesto-intro"] hgroup p {
    font-size: 1.5rem;
    line-height: 1.4;
    color: var(--fg-muted);
    max-width: 400px;
  }
  [data-section="manifesto-intro"] blockquote {
    border-left: 4px solid var(--azul);
    padding-left: 2rem;
    margin: 2rem 0;
    grid-column: 1;
  }
  [data-section="manifesto-intro"] blockquote p {
    font-size: 1.125rem;
    line-height: 1.4;
  }

  [data-section="principles"] {
    grid-column: 2;
    grid-row: 1 / span 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  [data-section="principles"] > div { display: flex; flex-direction: column; }
  [data-section="principles"] dt { font-weight: 700; font-size: 1.125rem; margin-bottom: 0.5rem; }
  [data-section="principles"] dd { font-size: 0.9rem; color: var(--fg-muted); margin: 0; }

  [data-section="palette"] {
    padding: 6rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  [data-palette] {
    display: flex;
    gap: 2rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
  }
  [data-palette] > li {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  [data-swatch] {
    display: block;
    width: 80px;
    height: 120px;
    border-radius: var(--r-1);
  }

  [data-section="lab"] { padding: 8rem 0; }
  [data-lab-grid] {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 4rem;
    margin-top: 2rem;
  }
  [data-lab-grid] + [data-lab-grid] { margin-top: 4rem; }
  [data-lab-grid] figure { margin: 0; }
  [data-lab-grid] figcaption { margin-bottom: 1rem; }
  [data-thumb] {
    height: 120px;
    background: var(--papel-20);
    border-radius: var(--r-1);
    margin-bottom: 1rem;
  }

  blockquote cite {
    font-style: normal;
    font-size: 0.875rem;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  [data-region="site-footer"] {
    padding: 3rem 2rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 1024px) {
    [data-section="manifesto-intro"] { grid-template-columns: 1fr; gap: 4rem; }
    [data-section="manifesto-intro"] hgroup h1 { font-size: 4rem; }
    [data-section="principles"] { grid-column: 1; grid-row: auto; }
  }
  @media (max-width: 768px) {
    [data-section="principles"] { grid-template-columns: 1fr; }
    [data-section="manifesto-intro"] hgroup h1 { font-size: clamp(3rem, 8vw, 6rem); }
  }
</style>
