---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import Card from '../components/Card.svelte';
import ProfileCard from '../components/ProfileCard.svelte';
import DataTable from '../components/DataTable.svelte';
import SearchBar from '../components/SearchBar.svelte';
import MetricCard from '../components/MetricCard.svelte';
---

<BaseLayout title="Recipes | COBOGÓ">
  <SiteNav currentPath={Astro.url.pathname} />

  <main>
    <header data-page-header>
      <hgroup>
        <h1>Recipes</h1>
        <p>Composições reusáveis dos componentes COBOGÓ aplicadas a casos cívicos.</p>
      </hgroup>
    </header>

    <section data-recipe="transparency-dashboard">
      <hgroup>
        <h2>Painel cívico de transparência</h2>
        <p>Dashboard com cards de métricas (mocks).</p>
      </hgroup>
      <div data-metric-grid>
        <MetricCard client:load value="R$ 4.2M" label="contratos ativos" accent="azul" />
        <MetricCard client:load value="127" label="fornecedores únicos" accent="verde" />
        <MetricCard client:load value="23" label="contratos vencendo em 30 dias" accent="vermelho" />
      </div>
    </section>

    <section data-recipe="search">
      <hgroup>
        <h2>Busca pública densa</h2>
        <p>Layout de 2 colunas com busca/filtros e tabela de resultados.</p>
      </hgroup>
      <div data-recipe-2col>
        <aside>
          <SearchBar
            client:load
            placeholder="Buscar contratos..."
            filters={[
              { id: 'ativos', label: 'Ativos', active: true },
              { id: 'encerrados', label: 'Encerrados', active: false },
              { id: 'pncp', label: 'PNCP', active: true }
            ]}
          />
        </aside>
        <div>
          <DataTable
            client:load
            caption="Resultados da busca: Contratos PNCP"
            headers={[
              { key: 'id', label: 'ID Contrato' },
              { key: 'objeto', label: 'Objeto' },
              { key: 'valor', label: 'Valor', align: 'right' },
              { key: 'status', label: 'Status', align: 'center' }
            ]}
            data={[
              { id: 'CT-2023-001', objeto: 'Aquisição de equipamentos de TI', valor: 'R$ 150.000,00', status: 'Ativo' },
              { id: 'CT-2023-042', objeto: 'Serviços de limpeza terceirizada', valor: 'R$ 45.200,00', status: 'Ativo' },
              { id: 'CT-2022-199', objeto: 'Manutenção de frota de veículos', valor: 'R$ 89.000,00', status: 'Concluído' },
              { id: 'CT-2023-088', objeto: 'Licenciamento de software ERP', valor: 'R$ 210.000,00', status: 'Pendente' },
              { id: 'CT-2021-005', objeto: 'Obras de reforma do telhado', valor: 'R$ 1.250.000,00', status: 'Cancelado' }
            ]}
          />
        </div>
      </div>
    </section>

    <section data-recipe="profile">
      <hgroup>
        <h2>Perfil de entidade pública</h2>
        <p>Card de perfil acompanhado de dados detalhados.</p>
      </hgroup>
      <div data-recipe-profile>
        <aside>
          <ProfileCard
            client:load
            name="Prefeitura Municipal"
            role="Entidade Executiva"
            tags={['CNPJ', 'Ativo']}
          />
        </aside>
        <div>
          <Card>
            <h3>Dados Gerais</h3>
            <p><strong>CNPJ:</strong> 00.000.000/0001-00</p>
            <p><strong>Endereço:</strong> Praça da Matriz, s/n - Centro</p>
          </Card>
          <Card>
            <h3>Contratos Vinculados</h3>
            <p>15 contratos ativos registrados no sistema.</p>
          </Card>
          <Card>
            <h3>Score de Transparência</h3>
            <p>Nota: <strong>8.5/10</strong></p>
          </Card>
        </div>
      </div>
    </section>

    <section data-recipe="longform">
      <hgroup>
        <h2>Longform jurídico denso</h2>
        <p>Página de leitura longa otimizada para textos jurídicos ou normativos.</p>
      </hgroup>

      <article data-longform>
        <h1>Termo de Referência nº 042/2023</h1>
        <h2>1. Objeto da Contratação</h2>

        <p>O presente documento tem por finalidade estabelecer as condições, critérios e exigências para a contratação de empresa especializada na prestação de serviços continuados, visando o suporte técnico e a manutenção preventiva e corretiva da infraestrutura tecnológica.</p>

        <p>A referida contratação justifica-se pela necessidade premente de assegurar a disponibilidade, integridade e segurança das informações geridas pela Administração Pública, em consonância com os princípios da eficiência e da continuidade dos serviços públicos essenciais estabelecidos na Constituição Federal.</p>

        <blockquote>
          "Art. 37. A administração pública direta e indireta de qualquer dos Poderes da União, dos Estados, do Distrito Federal e dos Municípios obedecerá aos princípios de legalidade, impessoalidade, moralidade, publicidade e eficiência."
        </blockquote>

        <h3>1.1. Das Obrigações da Contratada</h3>

        <p>A contratada deverá fornecer todo o ferramental, equipe técnica capacitada e insumos necessários à plena execução do objeto contratual. Eventuais inexecuções parciais ou totais sujeitarão a empresa às sanções administrativas previstas na Lei nº 14.133/2021 (Nova Lei de Licitações e Contratos Administrativos), sem prejuízo da reparação civil.</p>

        <pre><code>{`// Exemplo de integração com API do PNCP
const response = await fetch('https://pncp.gov.br/api/pncp/v1/contratos', {
  headers: {
    'Accept': 'application/json',
    'Authorization': 'Bearer {token}'
  }
});
const data = await response.json();`}</code></pre>

        <p>Ressalta-se, por derradeiro, que todas as etapas de fiscalização serão conduzidas por servidor público formalmente designado para o encargo de gestor e fiscal do contrato, a quem caberá atestar as notas fiscais e relatórios de medição de serviços.</p>
      </article>
    </section>
  </main>

  <footer data-region="site-footer">
    <p><small data-kicker>DS v0.1.0 — Distribuível via NPM / TypeScript Node</small></p>
  </footer>
</BaseLayout>

<style>
  main { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  main > [data-page-header] { padding: 6rem 0; border-bottom: 1px solid var(--border); margin-bottom: 0; }
  main > [data-page-header] hgroup h1 {
    font-family: var(--font-display-alt);
    font-size: 5rem;
    line-height: 0.9;
    margin: 0 0 2rem;
  }
  main > [data-page-header] hgroup p {
    font-size: 1.25rem;
    color: var(--fg-muted);
    max-width: 600px;
  }
  main > section { padding: 6rem 0; border-bottom: 1px solid var(--border); }
  main > section hgroup h2 { font-family: var(--font-display); font-size: 2rem; margin: 0 0 0.5rem; }
  main > section hgroup p { color: var(--fg-muted); margin: 0 0 3rem; }

  [data-metric-grid] {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  [data-recipe-2col], [data-recipe-profile] {
    display: flex;
    gap: 3rem;
  }
  [data-recipe-2col] > aside { width: 280px; flex-shrink: 0; }
  [data-recipe-2col] > div { flex: 1; min-width: 0; }
  [data-recipe-profile] > aside { width: 320px; flex-shrink: 0; }
  [data-recipe-profile] > div { flex: 1; display: flex; flex-direction: column; gap: 1rem; }

  [data-longform] {
    max-width: 680px;
    margin: 0 auto;
    padding: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }
  [data-longform] h1 {
    font-family: var(--font-display);
    font-size: var(--t-h1);
    margin: 0 0 2rem;
    line-height: var(--lh-tight);
  }
  [data-longform] h2 {
    font-family: var(--font-display);
    font-size: var(--t-h2);
    margin: 3rem 0 1.5rem;
  }
  [data-longform] h3 {
    font-family: var(--font-display);
    font-size: var(--t-h3);
    margin: 2.5rem 0 1rem;
  }
  [data-longform] p {
    font-family: var(--font-serif);
    font-size: var(--t-body);
    line-height: var(--lh-body);
    margin: 0 0 1.5rem;
  }
  [data-longform] blockquote {
    font-family: var(--font-serif);
    font-size: var(--t-h4);
    font-style: italic;
    line-height: 1.4;
    color: var(--fg-heading);
    margin: 3rem 0;
    padding: 2rem 2.5rem;
    background: var(--bg-raised);
    border-left: 4px solid var(--ocre);
    border-radius: 0 var(--r-soft) var(--r-soft) 0;
    box-shadow: var(--shadow-1);
  }
  [data-longform] pre {
    background-color: var(--concreto-90);
    color: var(--papel-00);
    padding: 1.5rem;
    border-radius: var(--r-soft);
    overflow-x: auto;
    margin: 2rem 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  [data-region="site-footer"] {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    color: var(--fg-muted);
  }

  @media (max-width: 768px) {
    [data-metric-grid] { grid-template-columns: 1fr; }
    [data-recipe-2col], [data-recipe-profile] { flex-direction: column; }
    [data-recipe-2col] > aside, [data-recipe-profile] > aside { width: 100%; }
    main > [data-page-header] hgroup h1 { font-size: clamp(3rem, 8vw, 5rem); }
  }
</style>
