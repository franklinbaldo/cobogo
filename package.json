{
  "name": "cobogo",
  "description": "A Brazilian modernist design system for public-interest software.",
  "keywords": [
    "cobogo",
    "design-system",
    "brazilian-modernism",
    "astro",
    "svelte",
    "civic-tech"
  ],
  "type": "module",
  "version": "0.1.0",
  "files": [
    "dist",
    "src/styles"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles": "./src/styles/global.css",
    "./components/*": {
      "svelte": "./dist/components/*.svelte",
      "default": "./dist/components/*.svelte"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:lib": "svelte-package -i src -o dist",
    "prepare": "svelte-package -i src -o dist",
    "preview": "astro preview"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/svelte": "^8.1.0",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@sveltejs/package": "^2.3.10",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "astro": "^6.3.1",
    "astro-expressive-code": "^0.41.7",
    "astro-pagefind": "^1.8.6",
    "jsdom": "^29.1.1",
    "svelte": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "svelte": "^5"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "dependencies": {
    "@picocss/pico": "^2.1.1"
  }
}
